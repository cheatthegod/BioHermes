#!/usr/bin/env bash
# biohermes — launch Hermes against a BioHermes-scoped profile dir.
#
# Creates and maintains a profile at `<repo>/.biohermes-profile/` (gitignored)
# which is seeded from `config-examples/biohermes-cli-config.yaml` on first
# invocation, with `<path-to-biohermes-checkout>` placeholders expanded to
# this checkout's absolute path.
#
# Hermes reads its config from `$HERMES_HOME/config.yaml` (see hermes_cli/
# config.py:210), so setting HERMES_HOME is the only knob that actually
# picks up the bio preset.  The user's real `~/.hermes/` is left alone.
#
# Usage:
#   biohermes                       # interactive chat
#   biohermes chat -q "hello"       # one-shot query
#   biohermes gateway               # run the messaging gateway
#   biohermes mcp list              # inspect registered MCP servers
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
PRESET_PATH="$REPO_ROOT/config-examples/biohermes-cli-config.yaml"
PROFILE_DIR="$REPO_ROOT/.biohermes-profile"

if [[ ! -f "$PRESET_PATH" ]]; then
  echo "biohermes: expected BioHermes config preset at $PRESET_PATH" >&2
  echo "biohermes: is this script running from inside a BioHermes checkout?" >&2
  exit 1
fi

HERMES_BIN="${HERMES_BIN:-$(command -v hermes || true)}"
if [[ -z "$HERMES_BIN" ]]; then
  echo "biohermes: \`hermes\` not found on PATH." >&2
  echo "biohermes: install hermes-agent with \`pip install -e .\` from the repo root, or set HERMES_BIN." >&2
  exit 1
fi

mkdir -p "$PROFILE_DIR"

# Optional explicit reseed: `biohermes --reseed-biohermes ...` backs up
# the existing config.yaml then re-emits from the preset.  Without this
# flag, we NEVER overwrite an existing profile config — the user may
# have edited it via `hermes config set`, slash-commands, or by hand,
# and silently re-seeding after a `git pull` that touched the preset
# would clobber those edits.
FORCE_RESEED=0
if [[ "${1:-}" == "--reseed-biohermes" ]]; then
  FORCE_RESEED=1
  shift
fi

CONFIG_TARGET="$PROFILE_DIR/config.yaml"
if [[ ! -f "$CONFIG_TARGET" ]]; then
  # First launch — seed from preset.
  sed "s|<path-to-biohermes-checkout>|$REPO_ROOT|g" "$PRESET_PATH" > "$CONFIG_TARGET"
elif [[ "$FORCE_RESEED" -eq 1 ]]; then
  backup="$CONFIG_TARGET.bak-$(date +%s)"
  mv "$CONFIG_TARGET" "$backup"
  sed "s|<path-to-biohermes-checkout>|$REPO_ROOT|g" "$PRESET_PATH" > "$CONFIG_TARGET"
  echo "biohermes: backed up existing config to $backup; reseeded from preset." >&2
fi

export BIOHERMES_REPO="$REPO_ROOT"
export HERMES_HOME="$PROFILE_DIR"

exec "$HERMES_BIN" "$@"
