#!/usr/bin/env bash
# biohermes — checkout-local launcher.
#
# Delegates all setup logic (config seed, skin install, splash, sibling-
# hermes resolution, profile dir choice) to `biohermes/cli.py` so there is
# a single source of truth.  Works without `pip install -e .` because we
# add the repo root to PYTHONPATH and invoke the cli module directly.
#
# After `pip install` the equivalent entry point is the `biohermes`
# console_script registered in pyproject.toml.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

# Find a Python with the right deps. Prefer:
#   1. Caller's PYTHON env var
#   2. Sibling python in same prefix as `hermes` (matches our hermes install)
#   3. Generic python3 on PATH
PYTHON="${PYTHON:-}"
if [[ -z "$PYTHON" ]]; then
  if [[ -n "${HERMES_BIN:-}" && -x "$(dirname "$HERMES_BIN")/python" ]]; then
    PYTHON="$(dirname "$HERMES_BIN")/python"
  else
    HBIN="$(command -v hermes 2>/dev/null || true)"
    if [[ -n "$HBIN" && -x "$(dirname "$HBIN")/python" ]]; then
      PYTHON="$(dirname "$HBIN")/python"
    else
      PYTHON="$(command -v python3)"
    fi
  fi
fi

# Add the repo root to PYTHONPATH so `biohermes` package is importable
# even before `pip install -e .`.
export PYTHONPATH="$REPO_ROOT${PYTHONPATH:+:$PYTHONPATH}"

exec "$PYTHON" -m biohermes.cli "$@"
