#!/usr/bin/env bash
# biohermes — checkout-local launcher.
#
# Delegates all setup logic (config seed, skin install, splash, sibling-
# hermes resolution, profile dir choice) to `biohermes/cli.py` so there is
# a single source of truth.  Works without `pip install -e .` because we
# add the repo root to PYTHONPATH and invoke the cli module directly.
#
# After `pip install` the equivalent entry point is the `biohermes`
# console_script registered in pyproject.toml.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

# Pick the Python that matches the hermes install — Hermes has many
# transitive deps (fire, anthropic, openai, …) that an arbitrary system
# python won't have.  Resolution order:
#   1. Caller's PYTHON env var (explicit override)
#   2. Shebang of the `hermes` console_script (most reliable: the script
#      itself records which interpreter has hermes-agent's deps)
#   3. Fallback: python3 on PATH (will likely fail with ModuleNotFoundError
#      if the install isn't done — this is intentional, surfaces the
#      problem instead of running a broken environment)
PYTHON="${PYTHON:-}"
if [[ -z "$PYTHON" ]]; then
  HBIN="${HERMES_BIN:-$(command -v hermes 2>/dev/null || true)}"
  if [[ -n "$HBIN" && -r "$HBIN" ]]; then
    SHEBANG="$(head -1 "$HBIN" 2>/dev/null)"
    if [[ "$SHEBANG" =~ ^#! ]]; then
      CAND="${SHEBANG#\#!}"
      # Drop trailing arguments (e.g. `#!/usr/bin/env python3` keeps just env;
      # but for a venv python it's normally a clean path).
      CAND="${CAND%% *}"
      if [[ -x "$CAND" ]]; then
        PYTHON="$CAND"
      fi
    fi
  fi
  if [[ -z "$PYTHON" ]]; then
    PYTHON="$(command -v python3)"
  fi
fi

# Add the repo root to PYTHONPATH so `biohermes` package is importable
# even before `pip install -e .`.
export PYTHONPATH="$REPO_ROOT${PYTHONPATH:+:$PYTHONPATH}"

exec "$PYTHON" -m biohermes.cli "$@"
